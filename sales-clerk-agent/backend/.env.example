# AI Core is accessed via a BTP Destination named "aicore-destination".
# No AICORE_SERVICE_KEY needed. The destination is resolved through the
# BTP Destination Service (destination-sales-clerk).
#
# For local dev: paste VCAP_SERVICES from:  cf env sales-clerk-agent-backend
# It must contain credentials for both "xsuaa" and "destination" services.
# The "destination" service credentials allow the SDK to fetch "aicore-destination"
# from BTP at runtime.

# Optional: override the BTP Destination name (default: aicore-destination)
# AICORE_DESTINATION_NAME=aicore-destination

# AI Core resource group that contains the gpt-4o deployment (default: default)
# AICORE_RESOURCE_GROUP=default

# BTP Destination name pointing to S/4HANA system
S4_DESTINATION_NAME=S4_SALESORDER_DEST

# BTP Destination name pointing to SAP AI Core instance
AICORE_DESTINATION_NAME=aicore-destination

# AI Core resource group that contains the gpt-4o deployment
AICORE_RESOURCE_GROUP=default

# VCAP_SERVICES for local development (CF injects this automatically in production)
# Paste the JSON from: cf env sales-clerk-agent-backend
VCAP_SERVICES={"xsuaa":[{"label":"xsuaa","plan":"application","name":"xsuaa-sales-clerk","credentials":{"clientid":"...","clientsecret":"...","url":"...","xsappname":"..."}}],"destination":[{"label":"destination","plan":"lite","name":"destination-sales-clerk","credentials":{"clientid":"...","clientsecret":"...","uri":"...","url":"..."}}]}

# Server port (default: 3000)
PORT=3000
